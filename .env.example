# Configuración de API Keys para generación de imágenes
# Copiar a .env y reemplazar con tus claves reales
# NUNCA commits .env a git (ya está en .gitignore)

# === GROQ (Obligatorio - Optimización de prompts) ===
# Obtenla en: https://console.groq.com/keys
# Ultra-rápido, gratis en beta
GROQ_API_KEY=gsk_

# === OPENAI (Para generar imágenes con DALL-E 3) ===
# Obtenla en: https://platform.openai.com/api-keys
# Mejor calidad de imágenes
OPENAI_API_KEY=sk-

# === GOOGLE GEMINI (Para generar imágenes con Gemini) ===
# Obtenla en: https://aistudio.google.com/app/apikey
# Gratis con crédito limitado
GOOGLE_API_KEY=AIza

# === HUGGING FACE (Para generar imágenes con Stable Diffusion) ===
# Obtenla en: https://huggingface.co/settings/tokens
# Gratis, modelos open source
HUGGINGFACE_API_KEY=hf_
